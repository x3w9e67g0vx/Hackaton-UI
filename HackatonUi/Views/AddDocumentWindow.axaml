<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:HackatonUi.Views"
        x:Class="HackatonUi.Views.AddDocumentWindow"
        Title="Добавить документ к зданию"
        Width="400" Height="350"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e2f"
        x:DataType="views:AddDocumentWindow">
  <StackPanel Margin="20" Spacing="10">
    <TextBlock Text="Добавление документа" 
               Foreground="White" 
               FontSize="20" 
               HorizontalAlignment="Center"/>
    <!-- Выбор здания -->
    <TextBlock Text="Выберите здание:" Foreground="White"/>
    <ComboBox x:Name="BuildingComboBox"
              Background="#2a2a3f" 
              Foreground="White"/>
    <!-- Ввод пути к файлу с кнопкой выбора -->
    <TextBlock Text="Путь к файлу:" Foreground="White"/>
    <StackPanel Orientation="Horizontal" Spacing="5">
      <TextBox x:Name="FilePathBox" 
               Background="#2a2a3f" 
               Foreground="White"
               Watermark="Введите путь к файлу"
               Width="250"/>
      <Button Content="Выбрать файл" 
              Click="SelectFile_Click" 
              Background="#4a4a7f" 
              Foreground="White" 
              Padding="5"/>
    </StackPanel>
    <!-- Ввод имени загрузчика -->
    <TextBlock Text="Загружено пользователем:" Foreground="White"/>
    <TextBox x:Name="UploaderBox" 
             Background="#2a2a3f" 
             Foreground="White"
             Watermark="Введите имя загрузчика"/>
    <!-- Выбор даты загрузки -->
    <TextBlock Text="Дата загрузки:" Foreground="White"/>
    <DatePicker x:Name="UploadDatePicker" 
                Background="#2a2a3f" 
                Foreground="White"/>
    <!-- Кнопка сохранения -->
    <Button Content="Сохранить документ" 
            Click="Save_Click"
            Background="#4a4a7f" 
            Foreground="White" 
            Padding="10" CornerRadius="5"/>
    <!-- Сообщение об операции -->
    <TextBlock x:Name="StatusText" Foreground="#ff6b6b"/>
  </StackPanel>
</Window>
