<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HackatonUi.Views.AddBuildingWindow"
        Title="Добавить здание"
        Width="400" Height="450"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e2f">
    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="Добавление здания" Foreground="White" FontSize="20" HorizontalAlignment="Center"/>

        <TextBlock Text="Адрес:" Foreground="White"/>
        <TextBox x:Name="AddressBox" Background="#2a2a3f" Foreground="White"/>

        <TextBlock Text="Кадастровый номер:" Foreground="White"/>
        <TextBox x:Name="CadastralBox" Background="#2a2a3f" Foreground="White"/>

        <TextBlock Text="Этажи:" Foreground="White"/>
        <TextBox x:Name="FloorsBox" Background="#2a2a3f" Foreground="White"/>

        <TextBlock Text="Площадь:" Foreground="White"/>
        <TextBox x:Name="AreaBox" Background="#2a2a3f" Foreground="White"/>

        <!--  ComboBox для выбора типа здания -->
        <TextBlock Text="Тип здания:" Foreground="White"/>
        <ComboBox x:Name="TypeComboBox"
                  Background="#2a2a3f" 
                  Foreground="White"
                  SelectedIndex="0">
            <ComboBoxItem Content="Жилой дом"/>
            <ComboBoxItem Content="Торговый центр"/>
            <ComboBoxItem Content="Промышленное здание"/>
        </ComboBox>

        <Button Content="Сохранить" Click="Save_Click" Background="#4a4a7f" Foreground="White" Padding="10" CornerRadius="5"/>
        <TextBlock x:Name="StatusText" Foreground="#ff6b6b"/>
    </StackPanel>
</Window>