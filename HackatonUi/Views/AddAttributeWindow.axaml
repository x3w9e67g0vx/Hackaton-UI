<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HackatonUi.Views.AddAttributeWindow"
        Title="Добавить атрибут к зданию"
        Width="400" Height="450"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e2f">
    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="Добавление атрибута к зданию" 
                   Foreground="White" FontSize="20" 
                   HorizontalAlignment="Center"/>
      
        <TextBlock Text="Выберите здание:" Foreground="White"/>
        <ComboBox x:Name="BuildingComboBox"
                  Background="#2a2a3f" Foreground="White"/>
      
        <TextBlock Text="Раздел:" Foreground="White"/>
        <TextBox x:Name="SectionBox" 
                  Background="#2a2a3f" Foreground="White"/>
      
        <TextBlock Text="Ключ:" Foreground="White"/>
        <TextBox x:Name="KeyBox" 
                 Background="#2a2a3f" Foreground="White"/>
      
        <TextBlock Text="Значение:" Foreground="White"/>
        <TextBox x:Name="ValueBox" 
                 Background="#2a2a3f" Foreground="White"/>
      
        <Button Content="Добавить атрибут" 
                Click="Save_Click"
                Background="#4a4a7f" 
                Foreground="White" 
                Padding="10" CornerRadius="5"/>
      
        <TextBlock x:Name="StatusText" Foreground="#ff6b6b"/>
    </StackPanel>
</Window>